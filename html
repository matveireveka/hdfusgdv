/* style.css — Общие стили для всех страниц */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Inter', sans-serif;
    background: #fefaf5;
    color: #000000;
    line-height: 1.5;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
}

/* Header & Navigation */
header {
    background: #2F4F4F;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
    border-bottom: 1px solid #708090;
    position: sticky;
    top: 0;
    z-index: 100;
}

.container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
}

.nav-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 0;
    flex-wrap: wrap;
}

.logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: #708090;
    letter-spacing: -0.5px;
}

.logo span {
    color: #506070;
    font-weight: 500;
}

.nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
}

.nav-links a {
    text-decoration: none;
    font-weight: 500;
    color: #506070;
    transition: 0.2s;
    font-size: 1rem;
    padding: 6px 0;
    border-bottom: 2px solid transparent;
}

.nav-links a:hover,
.nav-links a.active {
    color: #708090;
    border-bottom-color: #708090;
}

/* Hero секция */
.hero {
    background: linear-gradient(120deg, #f0f4f8, #e2e8f0);
    border-radius: 2rem;
    margin: 2rem 0;
    padding: 3rem 2rem;
    text-align: center;
}

.hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: 2.8rem;
    font-weight: 700;
    color: #506070;
}

.hero p {
    font-size: 1.2rem;
    max-width: 650px;
    margin: 1rem auto 0;
    color: #607080;
}

/* Заголовки секций */
.section-title {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    margin: 2rem 0 1.5rem;
    color: #405060;
    border-left: 6px solid #708090;
    padding-left: 1rem;
}

/* Сетка карточек рецептов */
.recipes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
}

/* Карточка рецепта */
.recipe-card {
    background: white;
    border-radius: 1.5rem;
    overflow: hidden;
    box-shadow: 0 8px 20px rgba(0,0,0,0.05);
    transition: transform 0.2s ease, box-shadow 0.2s;
    cursor: pointer;
}

.recipe-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 18px 30px rgba(0,0,0,0.1);
}

.card-img {
    height: 200px;
    overflow: hidden;
    background-color: #d2daf0;
    position: relative;
}

.card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
}

.recipe-card:hover .card-img img {
    transform: scale(1.05);
}

.card-content {
    padding: 1.5rem;
}

.card-content h3 {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
}

.card-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.85rem;
    color: #708090;
    margin-bottom: 0.8rem;
    flex-wrap: wrap;
}

.card-meta i {
    margin-right: 4px;
}

.card-desc {
    color: #405060;
    font-size: 0.9rem;
    margin-bottom: 1rem;
}

/* Кнопки */
.btn {
    display: inline-block;
    background: #708090;
    color: white;
    border: none;
    padding: 8px 18px;
    border-radius: 40px;
    font-weight: 500;
    cursor: pointer;
    transition: 0.2s;
    text-decoration: none;
    font-size: 0.85rem;
}

.btn-outline {
    background: transparent;
    border: 1.5px solid #708090;
    color: #708090;
}

.btn-outline:hover {
    background: #708090;
    color: white;
}

.btn:hover {
    background: #506070;
    transform: scale(0.97);
}

/* Фильтры */
.filters {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
}

.filter-btn {
    background: #e2e8f0;
    border: none;
    padding: 6px 18px;
    border-radius: 40px;
    font-weight: 500;
    cursor: pointer;
    color: #405060;
}

.filter-btn.active,
.filter-btn:hover {
    background: #708090;
    color: white;
}

/* Иконка избранного */
.favorite-icon {
    color: #b0c4de;
    cursor: pointer;
    transition: 0.1s;
    font-size: 1.4rem;
}

.favorite-icon.active {
    color: #e63946;
}

/* Форма добавления рецепта */
.add-recipe-section {
    background: #f0f4f8;
    border-radius: 1.8rem;
    padding: 2rem;
    margin: 2rem 0;
}

.form-group {
    margin-bottom: 1rem;
}

label {
    font-weight: 600;
    display: block;
    margin-bottom: 6px;
}

input,
textarea,
select {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid #cbd5e1;
    border-radius: 1.2rem;
    font-family: inherit;
    background: white;
}

.form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
}

button[type="submit"] {
    background: #708090;
    border: none;
    color: white;
    padding: 10px 24px;
    border-radius: 2rem;
    font-weight: bold;
    cursor: pointer;
}

/* Модальное окно */
.modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.7);
    justify-content: center;
    align-items: center;
    z-index: 1000;
}

.modal-content {
    background: #fffaf5;
    max-width: 700px;
    width: 90%;
    border-radius: 2rem;
    padding: 1.8rem;
    position: relative;
    max-height: 85vh;
    overflow-y: auto;
}

.close-modal {
    position: absolute;
    right: 1.5rem;
    top: 1rem;
    font-size: 1.8rem;
    cursor: pointer;
    color: #506070;
}

.modal-recipe-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    margin-bottom: 1rem;
}

.modal-ingredients,
.modal-steps {
    margin: 1.2rem 0;
}

.modal-ingredients h4,
.modal-steps h4 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
    border-left: 3px solid #708090;
    padding-left: 12px;
}

.modal-ingredients ul,
.modal-steps ol {
    margin-left: 1.5rem;
    margin-top: 0.5rem;
}

hr {
    margin: 1rem 0;
    border-color: #e2e8f0;
}

.modal-img {
    width: 100%;
    height: 250px;
    object-fit: cover;
    border-radius: 1rem;
    margin-bottom: 1rem;
}

/* Footer */
footer {
    background: #e2e8f0;
    text-align: center;
    padding: 1.5rem;
    margin-top: 3rem;
    font-size: 0.85rem;
    color: #405060;
}

/* Адаптивность */
@media (max-width: 720px) {
    .nav-bar {
        flex-direction: column;
        gap: 0.8rem;
    }
    .hero h1 {
        font-size: 2rem;
    }
    .form-row {
        grid-template-columns: 1fr;
    }
}

